{
  "name": "dualsense-tester",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bunx --bun vite --host",
    "build:icon": "bun run --filter 'fancy-controller' build",
    "preview": "vite preview",
    "build": "bunx --bun vite build",
    "build-only": "bunx --bun vite build",
    "type-check": "vue-tsc --noEmit -p ./tsconfig.app.json --composite false",
    "lint": "bunx --bun oxlint . --fix && bunx --bun eslint . --fix",
    "lint:migrate": "bunx --bun @oxlint/migrate ./eslint.config.mjs"
  },
  "dependencies": {
    "@unocss/reset": "^66.7.2",
    "@vercel/speed-insights": "^2.0.0",
    "@vueuse/core": "^14.3.0",
    "consola": "^3.4.2",
    "fancy-controller": "workspace:*",
    "floating-vue": "^5.2.2",
    "lodash-es": "^4.18.1",
    "motion-v": "^1.10.3",
    "pinia": "^3.0.4",
    "pixi.js": "^8.19.0",
    "reka-ui": "^2.9.10",
    "ufo": "^1.6.4",
    "vue": "^3.6.0-beta.16",
    "vue-i18n": "^11.4.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@iconify-json/icon-park-twotone": "^1.2.4",
    "@iconify-json/mingcute": "^1.2.7",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "^1.3.14",
    "@types/lodash-es": "^4.17.12",
    "@types/umami": "^2.10.1",
    "@types/w3c-web-hid": "^1.0.7",
    "@unocss/eslint-config": "^66.7.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.4",
    "eslint-plugin-oxlint": "^1.70.0",
    "oxlint": "^1.70.0",
    "rollup-plugin-bundle-stats": "^4.22.2",
    "rollup-plugin-webbundle": "^0.2.0",
    "sass-embedded": "^1.100.0",
    "simple-git": "^3.36.0",
    "typescript": "6.0.3",
    "unocss": "^66.7.2",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vue-tsc": "3.3.5",
    "wbn-sign": "^0.3.1",
    "workbox-routing": "^7.4.1"
  },
  "overrides": {
    "vite": "^8.0.0-beta.8"
  },
  "trustedDependencies": [
    "@swc/core"
  ],
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "^1.3.14"
    }
  }
}
